body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: url('background.jpg') no-repeat center center/cover;
    height: 100vh;
    color: white;
    text-align: center;
}

.container {
    position: absolute;
    top: 30%;
    width: 100%;
}

h1 {
    color: red;
    text-shadow: 0 0 10px red;
}

button {
    display: block;
    margin: 20px auto;
    padding: 15px 50px;
    font-size: 20px;
    border-radius: 10px;
    cursor: pointer;
}

.yes {
    background: black;
    color: white;
    border: 2px solid red;
}

.no {
    background: black;
    color: gray;
    border: 2px solid gray;
}

#result {
    font-size: 25px;
    margin-top: 20px;
}
